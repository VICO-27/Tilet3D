{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler rules */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,                                 // ✅ Fixes the allowImportingTsExtensions error
    "resolveJsonModule": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "jsx": "react-jsx",
    "strict": true,

    /* Path Aliases (baseUrl removed) */            // ✅ Fixes the TypeScript 6.0 deprecation error
    "paths": {
      "@/*": ["./src/*"],
      "@app/*": ["./src/app/*"],
      "@features/*": ["./src/features/*"],
      "@shared/*": ["./src/shared/*"]
    }
  },
  "include": ["src"]
}
